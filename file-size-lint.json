{
  "rules": [
    {
      "name": "equations-panel-entry",
      "include": [
        "client/src/components/home/equations-main-panel.tsx"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "maxLines": 650
    },
    {
      "name": "equations-panel-modules",
      "include": [
        "client/src/components/home/equations-main-panel"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "maxLines": 750
    },
    {
      "name": "equations-sidebar",
      "include": [
        "client/src/components/home/sidebar-equations-pane.tsx"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "maxLines": 250
    },
    {
      "name": "frame-grid-components",
      "include": [
        "client/src/components/frame-grid"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "maxLines": 550
    },
    {
      "name": "websocket-hooks",
      "include": [
        "client/src/hooks/ws"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "maxLines": 550
    },
    {
      "name": "dashboard-lib",
      "include": [
        "client/src/lib/dashboard"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "maxLines": 550
    },
    {
      "name": "equations-topic-infra",
      "include": [
        "client/src/lib/equations",
        "shared/equations-validation.ts",
        "shared/equations-mappings.ts",
        "shared/equations-pane.ts"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "maxLines": 550
    },
    {
      "name": "server-route-modules",
      "include": [
        "server/routes"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "maxLines": 550
    },
    {
      "name": "shared-tests",
      "include": [
        "shared/__tests__"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "maxLines": 550
    },
    {
      "name": "visualization-plugins",
      "include": [
        "examples/visualization-plugins"
      ],
      "extensions": [
        ".js",
        ".mjs"
      ],
      "maxLines": 550
    },
    {
      "name": "derivation-plugins",
      "include": [
        "examples/derivation-plugins"
      ],
      "extensions": [
        ".js",
        ".mjs"
      ],
      "maxLines": 550
    },
    {
      "name": "play-chase-modules",
      "include": [
        "examples/play/chase"
      ],
      "exclude": [
        "examples/play/chase/chase-regression.test.mjs",
        "examples/play/chase/decision-model/actions/chaser/action-strategies.mjs",
        "examples/play/chase/debug/decision-debug.mjs",
        "examples/play/chase/decision-model/strategies/chaser/evader-prediction/plan.mjs"
      ],
      "extensions": [
        ".mjs",
        ".ts"
      ],
      "maxLines": 550
    },
    {
      "name": "play-chase-regression-suite",
      "include": [
        "examples/play/chase/chase-regression.test.mjs"
      ],
      "extensions": [
        ".mjs"
      ],
      "maxLines": 2000
    },
    {
      "name": "play-chase-debug-ui",
      "include": [
        "examples/play/chase/debug/decision-debug.mjs"
      ],
      "extensions": [
        ".mjs"
      ],
      "maxLines": 1000
    },
    {
      "name": "play-chase-action-planning",
      "include": [
        "examples/play/chase/decision-model/actions/chaser/action-strategies.mjs"
      ],
      "extensions": [
        ".mjs"
      ],
      "maxLines": 900
    },
    {
      "name": "play-chase-chaser-evader-prediction-plan",
      "include": [
        "examples/play/chase/decision-model/strategies/chaser/evader-prediction/plan.mjs"
      ],
      "extensions": [
        ".mjs"
      ],
      "maxLines": 650
    },
    {
      "name": "repo-scripts",
      "include": [
        "scripts"
      ],
      "extensions": [
        ".js",
        ".mjs",
        ".ts",
        ".tsx"
      ],
      "maxLines": 550
    },
    {
      "name": "build-scripts",
      "include": [
        "script"
      ],
      "extensions": [
        ".js",
        ".mjs",
        ".ts",
        ".tsx"
      ],
      "maxLines": 550
    },
    {
      "name": "shared-schema",
      "include": [
        "shared/schema.ts"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "maxLines": 1000
    },
    {
      "name": "home-page",
      "include": [
        "client/src/pages/home.tsx"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ],
      "maxLines": 6500
    }
  ]
}
