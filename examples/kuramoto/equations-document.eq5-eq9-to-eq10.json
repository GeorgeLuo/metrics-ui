  "title": "Eq. 5 + Eq. 9 -> Eq. 10",
  "intro": [
    {
      "kind": "text",
      "value": "This derivation takes the order-parameter identity from Eq. 5 and substitutes the stationary density from Eq. 9, then separates the locked and drifting contributions into the self-consistency form of Eq. 10."
    }
  ],
