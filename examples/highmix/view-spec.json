{
  "name": "highmix-example-view",
  "version": 1,
  "ui": {
    "http": "http://127.0.0.1:5050",
    "ws": "ws://127.0.0.1:5050/ws/control"
  },
  "captures": [
    {
      "id": "legacy",
      "source": "/path/to/highmix-legacy_1_simulation.jsonl",
      "minTickCount": 100
    },
    {
      "id": "causal",
      "source": "/path/to/highmix-causal_1_simulation.jsonl",
      "minTickCount": 100
    }
  ],
  "selectedMetrics": [
    {
      "captureId": "legacy",
      "path": ["0", "job_release_summary", "total_jobs"]
    },
    {
      "captureId": "legacy",
      "path": ["0", "job_release_summary", "released_jobs"]
    },
    {
      "captureId": "legacy",
      "path": ["0", "job_release_summary", "pending_jobs"]
    },
    {
      "captureId": "legacy",
      "path": ["0", "job_release_summary", "completed_jobs"]
    },
    {
      "captureId": "causal",
      "path": ["0", "job_release_summary", "total_jobs"]
    },
    {
      "captureId": "causal",
      "path": ["0", "job_release_summary", "released_jobs"]
    },
    {
      "captureId": "causal",
      "path": ["0", "job_release_summary", "pending_jobs"]
    },
    {
      "captureId": "causal",
      "path": ["0", "job_release_summary", "completed_jobs"]
    }
  ],
  "annotations": [
    {
      "id": "highmix-startup",
      "tick": 120,
      "label": "Startup stabilization"
    },
    {
      "id": "highmix-shift-load",
      "tick": 360,
      "label": "Shift load change"
    },
    {
      "id": "highmix-throughput-rise",
      "tick": 560,
      "label": "Throughput inflection"
    },
    {
      "id": "highmix-end-window",
      "tick": 760,
      "label": "End-window comparison"
    }
  ],
  "visualization": {
    "pluginId": "highmix_factory_3d",
    "pluginFile": "examples/visualization-plugins/highmix_factory_3d.mjs",
    "captureId": "legacy",
    "requireVisualSignal": true
  }
}
